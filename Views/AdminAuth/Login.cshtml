@{
    Layout = null;
    ViewData["Title"] = "Login Admin";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Login Admin</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg,#5f2c82,#9c27b0);
            height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-wrapper {
            width: 1000px;
            height: 550px;
            background: white;
            border-radius: 30px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            animation: fadeIn 0.5s ease;
        }

        .left {
            width: 50%;
            background: linear-gradient(135deg,#7b2cbf,#9c27b0);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .left::before {
            content: "";
            position: absolute;
            width: 120%;
            height: 120%;
            background: white;
            border-radius: 50%;
            left: -60%;
        }

        .left img {
            position: relative;
            width: 80%;
            z-index: 2;
        }

        .right {
            width: 50%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .top-img {
            width: 120px;
            margin: 0 auto 10px auto;
        }

        .admin-title {
            text-align: center;
            font-weight: bold;
            color: #9c27b0;
            margin-bottom: 20px;
        }

        .input-group-custom {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #ccc;
        }

        .input-group-custom i {
            color: #9c27b0;
            margin-right: 10px;
        }

        .input-group-custom input {
            border: none;
            width: 100%;
            outline: none;
        }

        .btn-login {
            background: #9c27b0;
            color: white;
            border-radius: 25px;
            padding: 10px;
            border: none;
        }

        .btn-login:hover {
            background: #7b1fa2;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>
</head>

<body>

<div class="login-wrapper">

    <div class="left">
        <img src="~/img/Reset password-cuate.png" />
    </div>

    <div class="right">

        <img src="~/img/Security-amico.png" class="top-img" />

        <h4 class="admin-title">
            <i class="bi bi-shield-lock"></i> Panel Administrativo
        </h4>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">
                <i class="bi bi-exclamation-triangle"></i>
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">

            <div class="input-group-custom">
                <i class="bi bi-envelope"></i>
                <input name="correo" type="email" placeholder="Correo administrador" required />
            </div>

            <div class="input-group-custom">
                <i class="bi bi-lock"></i>
                <input name="password" type="password" placeholder="Contraseña" required />
            </div>

            <button type="submit" class="btn-login w-100">
                <i class="bi bi-box-arrow-in-right"></i> Ingresar
            </button>

        </form>

    </div>

</div>

</body>
</html>