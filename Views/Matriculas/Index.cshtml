@model IEnumerable<ProyectoFinal_VillarrealHugo.Models.Matricula>

@{
	ViewData["Title"] = "Mis Matrículas";
}

<style>
	body {
		background: linear-gradient(135deg, #5f2c82, #9c27b0);
		color: white;
	}

	.titulo {
		text-align: center;
		margin-top: 40px;
		margin-bottom: 30px;
	}

	.contenedor {
		max-width: 950px;
		margin: auto;
	}

	.card-matricula {
		background: white;
		color: black;
		border-radius: 20px;
		padding: 25px;
		margin-bottom: 25px;
		box-shadow: 0 15px 35px rgba(0,0,0,0.3);
		transition: all 0.3s ease;
	}

		.card-matricula:hover {
			transform: translateY(-5px);
		}

	.header-card {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.badge-estado {
		padding: 6px 14px;
		border-radius: 20px;
		font-size: 12px;
		color: white;
	}

	.curso-item {
		background: #f3f3f3;
		padding: 10px 15px;
		border-radius: 10px;
		margin-bottom: 6px;
	}

	.total {
		font-weight: bold;
		margin-top: 10px;
		font-size: 16px;
	}

	.btn-custom {
		border-radius: 25px;
		padding: 8px 15px;
		font-size: 14px;
	}
</style>

<div class="titulo">
	<h2><i class="bi bi-journal-check"></i> Mis Matrículas</h2>
	<p>Consulta, edita y paga tus cursos</p>
</div>

<div class="contenedor">

	@foreach (var matricula in Model)
	{
		<div class="card-matricula">

			<!-- HEADER -->
			<div class="header-card">
				<span>
					<i class="bi bi-calendar"></i>
					<strong>Fecha:</strong> @matricula.Fecha.ToShortDateString()
				</span>

				<span class="badge-estado"
					  style="background:@(matricula.Estado == "Confirmada" ? "#28a745" : "#ffc107")">
					<i class="bi @(matricula.Estado == "Confirmada" ? "bi-check-circle" : "bi-clock")"></i>
					@matricula.Estado
				</span>
			</div>

			<!-- CURSOS -->
			<div class="mt-3">
				<h6><i class="bi bi-book"></i> Cursos:</h6>

				@foreach (var d in matricula.Detalles)
				{
					<div class="curso-item">
						<i class="bi bi-bookmark-fill text-primary"></i>
						@d.Curso.Nombre
						(<strong>@d.Curso.Creditos</strong> créditos)
					</div>
				}
			</div>

			<!-- TOTAL -->
			<div class="total">
				<i class="bi bi-calculator"></i>
				Total: @matricula.Total créditos
			</div>

			<!-- ESTADO PAGO -->
			<p class="mt-2">
				<i class="bi bi-credit-card"></i>
				<strong>Pago:</strong>

				<span style="color:@(matricula.EstadoPago == "Pagado" ? "green" : "orange")">
					<i class="bi @(matricula.EstadoPago == "Pagado" ? "bi-check-circle-fill" : "bi-hourglass-split")"></i>
					@matricula.EstadoPago
				</span>
			</p>

			<!-- BOTONES -->
			<div class="d-flex justify-content-between align-items-center mt-3">

				<!-- ELIMINAR -->
				@if (matricula.EstadoPago == "Pendiente")
				{
					<button class="btn btn-danger btn-custom"
							data-bs-toggle="modal"
							data-bs-target="#modalEliminar"
							data-id="@matricula.Id">
						<i class="bi bi-trash"></i> Eliminar
					</button>
				}
				else
				{
					<span></span>
				}

				<div>

					@if (matricula.EstadoPago == "Pendiente")
					{
						<!-- EDITAR -->
						<a asp-action="Editar"
							   asp-route-id="@matricula.Id"
							   class="btn btn-warning btn-custom">
							<i class="bi bi-pencil-square"></i> Editar
						</a>

						<!-- PAGAR -->
						<form asp-action="Pagar" method="post" style="display:inline;">
							<input type="hidden" name="id" value="@matricula.Id" />

							<button class="btn btn-success btn-custom">
								<i class="bi bi-credit-card-2-front"></i> Pagar
							</button>
						</form>
					}
					else
					{
						<button class="btn btn-secondary btn-custom" disabled>
							<i class="bi bi-check-circle"></i> Pagado
						</button>
					}

					<!-- VER -->
					<a asp-action="Confirmacion"
						   asp-route-id="@matricula.Id"
						   class="btn btn-primary btn-custom ms-2">
						<i class="bi bi-eye"></i> Ver
					</a>

				</div>

			</div>

		</div>
	}

</div>

<!-- ================= MODAL ELIMINAR ================= -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
	<div class="modal-dialog">
		<div class="modal-content">

			<div class="modal-header bg-danger text-white">
				<h5 class="modal-title">
					<i class="bi bi-exclamation-triangle"></i> Confirmar eliminación
				</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>

			<div class="modal-body text-center">

				<i class="bi bi-exclamation-circle text-danger" style="font-size:40px;"></i>

				<p class="mt-3">
					¿Seguro que deseas eliminar esta matrícula?
				</p>

				<small class="text-muted">
					Esta acción no se puede deshacer
				</small>

			</div>

			<div class="modal-footer">

				<form id="formEliminar" method="post" asp-action="EliminarMatricula">
					<input type="hidden" name="id" id="matriculaId" />

					<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
						Cancelar
					</button>

					<button type="submit" class="btn btn-danger">
						<i class="bi bi-trash"></i> Eliminar
					</button>
				</form>

			</div>

		</div>
	</div>
</div>

<!-- ================= SCRIPT ================= -->
<script>
	var modalEliminar = document.getElementById('modalEliminar');

	modalEliminar.addEventListener('show.bs.modal', function (event) {
		var button = event.relatedTarget;
		var id = button.getAttribute('data-id');

		document.getElementById('matriculaId').value = id;
	});
</script>