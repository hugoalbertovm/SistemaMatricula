@{
    ViewData["Title"] = "Dashboard";
}

<style>
    body {
        background: linear-gradient(135deg, #5f2c82, #9c27b0);
        color: white;
    }

    .titulo {
        text-align: center;
        margin-top: 40px;
    }

    .cards {
        display: flex;
        gap: 25px;
        justify-content: center;
        margin-top: 50px;
        flex-wrap: wrap;
    }

    .card-box {
        background: white;
        color: black;
        padding: 25px;
        border-radius: 20px;
        width: 220px;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        transition: all 0.3s ease;
    }

        .card-box:hover {
            transform: translateY(-8px);
        }

    .icono {
        font-size: 40px;
        color: #9c27b0;
        margin-bottom: 10px;
    }

    .numero {
        font-size: 28px;
        font-weight: bold;
    }

    .btn-panel {
        margin-top: 10px;
        background: #9c27b0;
        color: white;
        border-radius: 25px;
    }

        .btn-panel:hover {
            background: #7b1fa2;
        }

    .bienvenida {
        text-align: center;
        margin-top: 10px;
        opacity: 0.9;
    }
</style>

<div class="titulo">
    <h2><i class="bi bi-speedometer2"></i> Panel Administrativo</h2>
    <p class="bienvenida">Gestiona el sistema de forma rápida y sencilla</p>
</div>

<div class="cards">

    <!-- CARRERAS -->
    <div class="card-box">
        <i class="bi bi-mortarboard-fill icono"></i>
        <div class="numero">@ViewBag.Carreras</div>
        <p>Carreras</p>
        <a asp-controller="Carreras" asp-action="Index" class="btn btn-panel">
            <i class="bi bi-gear"></i> Gestionar
        </a>
    </div>

    <!-- CURSOS -->
    <div class="card-box">
        <i class="bi bi-book-fill icono"></i>
        <div class="numero">@ViewBag.Cursos</div>
        <p>Cursos</p>
        <a asp-controller="Cursos" asp-action="Index" class="btn btn-panel">
            <i class="bi bi-gear"></i> Gestionar
        </a>
    </div>

    <!-- ESTUDIANTES -->
    <div class="card-box">
        <i class="bi bi-people-fill icono"></i>
        <div class="numero">@ViewBag.Estudiantes</div>
        <p>Estudiantes</p>
        <a asp-controller="Estudiantes" asp-action="Index" class="btn btn-panel">
            <i class="bi bi-eye"></i> Ver
        </a>
    </div>

    <!-- MATRÍCULAS -->
    <div class="card-box">
        <i class="bi bi-journal-check icono"></i>
        <div class="numero">@ViewBag.Matriculas</div>
        <p>Matrículas</p>
        <a asp-controller="Matriculas" asp-action="Index" class="btn btn-panel">
            <i class="bi bi-eye"></i> Ver
        </a>
    </div>

</div>