@model ProyectoFinal_VillarrealHugo.Models.Carrera

@{
    ViewData["Title"] = "Editar Carrera";
}

<style>
    body {
        background: linear-gradient(135deg,#5f2c82,#9c27b0);
    }

    .contenedor {
        max-width: 500px;
        margin: auto;
        margin-top: 60px;
    }

    .card-form {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        animation: fadeIn 0.3s ease;
    }

    .input-group-custom {
        display: flex;
        align-items: center;
        border-bottom: 2px solid #ccc;
        margin-bottom: 20px;
    }

    .input-group-custom i {
        color: #9c27b0;
        margin-right: 10px;
    }

    .input-group-custom input {
        border: none;
        outline: none;
        width: 100%;
        padding: 8px;
    }

    .btn-custom {
        border-radius: 25px;
        padding: 8px 18px;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

<div class="contenedor">

    <div class="card-form">

        <h3 class="text-center mb-4">
            <i class="bi bi-pencil-square"></i>
            Editar Carrera
        </h3>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <!-- NOMBRE -->
            <div class="input-group-custom">
                <i class="bi bi-bookmark"></i>
                <input asp-for="Nombre" placeholder="Nombre de la carrera" />
            </div>
            <span asp-validation-for="Nombre" class="text-danger"></span>

            <!-- DURACION -->
            <div class="input-group-custom">
                <i class="bi bi-clock"></i>
                <input asp-for="Duracion" type="number" placeholder="Duración (años)" />
            </div>
            <span asp-validation-for="Duracion" class="text-danger"></span>

            <!-- BOTONES -->
            <div class="text-center mt-4">

                <button class="btn btn-primary btn-custom">
                    <i class="bi bi-save"></i> Actualizar
                </button>

                <a asp-action="Index" class="btn btn-secondary btn-custom ms-2">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}